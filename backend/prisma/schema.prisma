// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
}

model Victim {
  id               String             @id @default(uuid())
  name             String
  cpf              String             // Encrypted
  cpfHash          String             @unique // Hashed for lookup
  incidents        Occurrence[]
  emergencyContacts EmergencyContact[]
  emergencyAlerts  EmergencyAlert[]
  createdAt        DateTime           @default(now())
}

model Aggressor {
  id        String   @id @default(uuid())
  name      String
  cpf       String   // Encrypted
  cpfHash   String   @unique // Hashed for lookup
  occurrences Occurrence[]
}

model Occurrence {
  id          String   @id @default(uuid())
  description String
  latitude    Float
  longitude   Float
  victimId    String
  victim      Victim   @relation(fields: [victimId], references: [id])
  aggressorId String
  aggressor   Aggressor @relation(fields: [aggressorId], references: [id])
}

model EmergencyContact {
  id           String   @id @default(uuid())
  name         String
  phone        String   // Encrypted
  email        String?  // Encrypted
  relationship String
  priority     Int      @default(1)
  victimId     String
  victim       Victim   @relation(fields: [victimId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([victimId])
}

model EmergencyAlert {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  address   String?
  status    String   @default("PENDING")
  victimId  String?
  victim    Victim?  @relation(fields: [victimId], references: [id])
  createdAt DateTime @default(now())

  @@index([victimId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  VICTIM
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource])
}
