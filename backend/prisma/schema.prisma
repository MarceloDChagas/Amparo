// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
}

model Aggressor {
  id        String   @id @default(uuid())
  name      String
  cpf       String   // Encrypted
  cpfHash   String   @unique // Hashed for lookup
  occurrences Occurrence[]
}

model Occurrence {
  id          String   @id @default(uuid())
  description String
  latitude    Float
  longitude   Float
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  aggressorId String
  aggressor   Aggressor @relation(fields: [aggressorId], references: [id])
}

model EmergencyContact {
  id           String   @id @default(uuid())
  name         String
  phone        String   // Encrypted
  email        String?  // Encrypted
  relationship String
  priority     Int      @default(1)
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model EmergencyAlert {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  address   String?
  status    String   @default("PENDING")
  userId  String?
  user    User?  @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  
  // Victim specific fields (Optional because Admins/Normal Users don't have them)
  cpf       String?  // Encrypted
  cpfHash   String?  @unique // Hashed for lookup

  occurrences      Occurrence[]
  emergencyContacts EmergencyContact[]
  emergencyAlerts   EmergencyAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  VICTIM
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource])
}
