// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Aggressor {
  id          String       @id @default(uuid())
  name        String
  cpf         String // Encrypted
  cpfHash     String       @unique // Hashed for lookup
  occurrences Occurrence[]
}

model Occurrence {
  id          String     @id @default(uuid())
  description String
  latitude    Float
  longitude   Float
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  aggressorId String?
  aggressor   Aggressor? @relation(fields: [aggressorId], references: [id])
  notes       Note[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model EmergencyContact {
  id           String   @id @default(uuid())
  name         String
  phone        String // Encrypted
  email        String? // Encrypted
  relationship String
  priority     Int      @default(1)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model EmergencyAlert {
  id               String            @id @default(uuid())
  latitude         Float
  longitude        Float
  address          String?
  status              String            @default("PENDING")
  cancellationReason  String?
  userId              String?
  user             User?             @relation(fields: [userId], references: [id])
  createdAt        DateTime          @default(now())
  notificationLogs NotificationLog[]
  events           AlertEvent[]

  @@index([userId])
  @@index([status, createdAt]) 
}

model NotificationLog {
  id           String         @id @default(uuid())
  alertId      String
  alert        EmergencyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  contactEmail String?
  contactName  String
  channel      String         @default("EMAIL") // EMAIL | PUSH
  status       String // SENT | FAILED
  errorMessage String?
  attempt      Int            @default(1)
  createdAt    DateTime       @default(now())

  @@index([alertId, createdAt]) 
  @@index([status])
}

enum AlertEventType {
  LOCATION_UPDATE
  NOTIFICATION_SENT
  STATUS_CHANGE
  COMMENT
  CREATED
}

enum EventSource {
  SYSTEM
  ADMIN
  USER
}

model AlertEvent {
  id        String         @id @default(uuid())
  alertId   String
  alert     EmergencyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  type      AlertEventType
  source    EventSource    @default(SYSTEM)
  message   String
  metadata  String? // Extra data stringified
  createdAt DateTime       @default(now())

  @@index([alertId, createdAt]) 
  @@index([type])
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  role     Role   @default(USER)

  // Victim specific fields (Optional because Admins/Normal Users don't have them)
  cpf     String? // Encrypted
  cpfHash String? @unique // Hashed for lookup

  occurrences       Occurrence[]
  emergencyContacts EmergencyContact[]
  emergencyAlerts   EmergencyAlert[]
  notifications     Notification[]
  checkIns          CheckIn[]
  notes             Note[]
  documents         Document[]
  safeLocations     SafeLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  VICTIM
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource])
}

enum NotificationCategory {
  ALERT
  SUCCESS
  WARNING
  INFO
  MAINTENANCE
}

model Notification {
  id        String               @id @default(uuid())
  title     String
  body      String
  category  NotificationCategory @default(INFO)
  targetId  String? // null = broadcast to all VICTIM users
  target    User?                @relation(fields: [targetId], references: [id], onDelete: Cascade)
  read      Boolean              @default(false)
  createdAt DateTime             @default(now())

  @@index([targetId, createdAt]) 
  @@index([read])
  @@index([category])
}

model CheckIn {
  id                  String    @id @default(uuid())
  startTime           DateTime  @default(now())
  expectedArrivalTime DateTime
  actualArrivalTime   DateTime?
  startLatitude       Float?
  startLongitude      Float?
  finalLatitude       Float?
  finalLongitude      Float?
  distanceType        String // SHORT | MEDIUM | LONG
  status              String    @default("ACTIVE") // ACTIVE | ON_TIME | LATE | CANCELLED
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // RN03 — escalonamento progressivo: +5min in-app → +15min email P1 → +30min email P2/P3 → +45min alerta crítico
  overdueAt           DateTime? // quando o check-in se tornou LATE pela primeira vez
  escalationStage     Int       @default(0) // 0=nenhum 1=in-app 2=email P1 3=email P2/P3 4=alerta crítico
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, expectedArrivalTime])
  @@index([status, escalationStage, overdueAt])
  @@index([userId, createdAt])
}

model Note {
  id      String  @id @default(uuid())
  title   String?
  content String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  occurrenceId String?
  occurrence   Occurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([occurrenceId])
}

model HeatMapCell {
  id             String   @id @default(uuid())
  cellKey        String   @unique // Stable identifier for the grid cell (e.g., geohash or tile index)
  latitude       Float
  longitude      Float
  intensity      Int      @default(1) // Número de ocorrências na célula
  riskScore      Float    @default(0) // Score ponderado por tipo de ocorrência
  lastOccurrence DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([latitude, longitude])
  @@index([intensity])
  @@index([riskScore])
  @@index([lastOccurrence])
}

enum PatrolRouteStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model PatrolRoute {
  id         String             @id @default(uuid())
  name       String // Ex: "Rota Carnaval - Centro"
  waypoints  String // JSON: Array<{ latitude: Float, longitude: Float, order: Int }>
  status     PatrolRouteStatus  @default(PENDING)
  assignedTo String? // ID do agente/viatura responsável
  generatedBy String? // ID do admin que gerou a rota
  scheduledAt DateTime?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

model SafeLocation {
  id        String   @id @default(uuid())
  name      String // Ex: "Casa", "Trabalho", "Academia"
  address   String?
  latitude  Float
  longitude Float
  radius    Int      @default(200) // Raio em metros para geofencing (RN06)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Document {
  id          String  @id @default(uuid())
  fileName    String
  contentType String
  storageKey  String  @unique
  sizeBytes   Int?

  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadedBy String? // ID do admin que fez o upload

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt]) 
}
