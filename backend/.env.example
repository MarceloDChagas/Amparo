DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amparo?schema=public"
PORT=3000

# ===== MinIO / Storage =====
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=amparo-docs

# ===== SMTP Configuration for Email Notifications =====
# Gmail SMTP Configuration (use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ===== JWT Configuration =====
JWT_SECRET="your-secret-key"
JWT_EXPIRES_IN="1d"

# ===== Seed Admin User =====
SEED_ADMIN_EMAIL="admin@amparo.local"
SEED_ADMIN_PASSWORD="Admin@123"
SEED_ADMIN_NAME="Administrador"

# ===== Encryption (LGPD) =====
# AES-256 key: must be exactly 32 characters
ENCRYPTION_KEY="your-32-char-encryption-key-here"

